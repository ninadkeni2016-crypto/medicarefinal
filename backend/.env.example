PORT=5000
MONGODB_URI=mongodb://localhost:27017/careconnectpro
MONGO_URI=mongodb://localhost:27017/careconnectpro
JWT_SECRET=your_jwt_secret_here
NODE_ENV=development
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password

# When true, API returns dummy data so the UI is never empty. Set to false for production.
DEMO_MODE=true

# Optional: email (e.g. for OTP)
# EMAIL_USER=
# EMAIL_PASS=
